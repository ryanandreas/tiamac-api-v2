generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
  engineType    = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String                 @id @default(uuid()) @map("uuid")
  name             String
  email            String                 @unique
  password         String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  lastLogin        DateTime?
  status           UserStatus             @default(ACTIVE)
  emailVerified    Boolean                @default(false)
  image            String?
  accounts         Account[]
  customerProfile  CustomerProfile?
  materialUsages   ServiceMaterialUsage[]
  statusChanges    ServiceStatusHistory[]
  customerServices Services[]             @relation("CustomerServices")
  teknisiServices  Services[]             @relation("TeknisiServices")
  sessions         Session[]
  staffProfile     StaffProfile?
  stockMovements   StockMovement[]

  @@map("users")
}

model CustomerProfile {
  userId    String   @id
  no_telp   String
  provinsi  String?
  alamat    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("customer_profiles")
}

model StaffProfile {
  userId      String   @id
  role        String
  no_telp     String?
  wilayah     String?
  bio         String?
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@map("staff_profiles")
}

model Services {
  id                   String                 @id @default(uuid()) @db.Uuid
  customerId           String
  jenis_servis         String
  keluhan              String
  status               String
  status_servis        String
  alamat_servis        String?
  biaya                Int?
  teknisiId            String?
  biaya_dasar          Int?                   @default(50000)
  estimasi_biaya       Int?
  biaya_disetujui      Boolean                @default(false)
  bukti_foto_before    String?
  bukti_foto_after     String?
  garansi_aktif_sampai DateTime?
  alasan_batal         String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  acUnits              ServiceAcUnit[]
  materialUsages       ServiceMaterialUsage[]
  statusHistory        ServiceStatusHistory[]
  customer             User                   @relation("CustomerServices", fields: [customerId], references: [id])
  teknisi              User?                  @relation("TeknisiServices", fields: [teknisiId], references: [id])
  payments             ServicePayment[]

  @@map("services")
}

model ServiceAcUnit {
  id        String                 @id @default(uuid())
  serviceId String                 @db.Uuid
  pk        String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  layanan   ServiceAcUnitLayanan[]
  service   Services               @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_ac_units")
}

model ServiceAcUnitLayanan {
  id        String            @id @default(uuid())
  unitId    String
  catalogId String?
  nama      String
  harga     Int
  createdAt DateTime          @default(now())
  catalog   AcServiceCatalog? @relation(fields: [catalogId], references: [uuid])
  unit      ServiceAcUnit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@index([catalogId])
  @@map("service_ac_unit_layanans")
}

model AcServiceCatalog {
  uuid         String                 @id @default(uuid())
  nama         String
  pk           String?
  harga        Int
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  unitLayanans ServiceAcUnitLayanan[]

  @@unique([nama, pk])
  @@map("ac_service_catalog")
}

model InventoryItem {
  id             String                 @id @default(uuid())
  sku            String                 @unique
  nama           String
  uom            InventoryUom
  harga          Int
  qtyOnHand      Int                    @default(0)
  minStock       Int?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  materialUsages ServiceMaterialUsage[]
  movements      StockMovement[]

  @@map("inventory_items")
}

model StockMovement {
  id              String             @id @default(uuid())
  itemId          String
  type            StockMovementType
  qty             Int
  referenceType   StockReferenceType
  referenceId     String?
  notes           String?
  createdByUserId String?
  createdAt       DateTime           @default(now())
  createdBy       User?              @relation(fields: [createdByUserId], references: [id])
  item            InventoryItem      @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@index([referenceType, referenceId])
  @@map("stock_movements")
}

model ServiceMaterialUsage {
  id              String        @id @default(uuid())
  serviceId       String        @db.Uuid
  itemId          String
  qty             Float
  harga_satuan    Int
  notes           String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  createdBy       User?         @relation(fields: [createdByUserId], references: [id])
  item            InventoryItem @relation(fields: [itemId], references: [id])
  service         Services      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([serviceId])
  @@map("service_material_usages")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id           String    @id @default(uuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model ServiceStatusHistory {
  id              String   @id @default(uuid())
  serviceId       String        @db.Uuid
  status          String
  status_servis   String
  notes           String?
  changedByUserId String?
  createdAt       DateTime @default(now())
  changedBy       User?    @relation(fields: [changedByUserId], references: [id])
  service         Services @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_status_history")
}

model ServicePayment {
  id                    String      @id @default(uuid())
  serviceId             String      @db.Uuid
  type                  PaymentType
  amount                Int
  status                String      @default("PENDING")
  metodePembayaran      String?
  bank                  String?
  vaNumber              String?
  qrUrl                 String?
  paymentDetails        Json?
  midtransTransactionId String?
  waktuPembayaran       DateTime?
  expiryTime            DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  service               Services    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@map("service_payments")
}

enum PaymentType {
  DOWN_PAYMENT
  FULL_PAYMENT
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum StockReferenceType {
  ADMIN_ADD
  SERVICE_USAGE
  STOCK_OPNAME
}

enum InventoryUom {
  pcs
  meter
  set
  btg
  roll
  kg
  liter
  tabung
}
